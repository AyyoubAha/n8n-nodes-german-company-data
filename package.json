{
	"name": "n8n-nodes-german-company-data",
	"version": "0.1.2",
	"description": "n8n community node for verified German company data: KYB company profiles (Handelsregister, VIES VAT, Bundesanzeiger), insolvency register checks and Impressum contact extraction — powered by Apify actors.",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"apify",
		"kyb",
		"know-your-business",
		"german",
		"germany",
		"dach",
		"handelsregister",
		"impressum",
		"insolvency",
		"insolvenz",
		"vat",
		"vies",
		"ust-idnr",
		"company-data",
		"lead-generation",
		"compliance"
	],
	"license": "MIT",
	"author": {
		"name": "Ayyoub Aharchi",
		"email": "kontakt@ayyoubaharchi.de"
	},
	"homepage": "https://apify.com/ayyouba/dach-company-intel",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AyyoubAha/n8n-nodes-german-company-data.git"
	},
	"bugs": {
		"url": "https://github.com/AyyoubAha/n8n-nodes-german-company-data/issues"
	},
	"engines": {
		"node": ">=20.15"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && node scripts/copy-assets.mjs",
		"dev": "tsc --watch",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/GermanCompanyDataApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/GermanCompanyData/GermanCompanyData.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.40.2",
		"@types/node": "^26.1.1",
		"@typescript-eslint/parser": "^8.65.0",
		"eslint": "^9.39.5",
		"eslint-plugin-n8n-nodes-base": "^1.16.7",
		"jsonc-eslint-parser": "^2.4.0",
		"n8n-workflow": "^2.16.0",
		"prettier": "^3.9.6",
		"release-it": "^20.2.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
