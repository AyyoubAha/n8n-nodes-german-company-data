{
	"compilerOptions": {
		"strict": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"target": "es2021",
		"lib": ["es2021"],
		"declaration": false,
		"sourceMap": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"useUnknownInCatchVariables": false,
		"noUnusedLocals": true,
		"outDir": "./dist/",
		"types": ["node"]
	},
	"include": ["credentials/**/*.ts", "nodes/**/*.ts", "package.json"]
}
